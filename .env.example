# HubSpot ↔ Mautic Sync - Environment Variables
# Copy to .env and fill in your values. Never commit .env to Git.

# -- HubSpot --------------------------------------------------------
# Private App token with scopes: crm.lists.read, crm.lists.write,
# crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_PRIVATE_APP_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -- Mautic ---------------------------------------------------------
# Root URL of your Mautic instance (no trailing slash, no /api or /s)
MAUTIC_BASE_URL=https://your-mautic-domain.com
MAUTIC_USERNAME=admin@yourdomain.com
MAUTIC_PASSWORD=your_mautic_password

# -- Microsoft Teams Notifications (optional) -----------------------
TEAMS_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=

# -- Local dev only -------------------------------------------------
# The CLI auto-loads .env if it exists. No need to set this manually.
# Set LOAD_DOTENV=1 if you are calling the module from a custom script.
# LOAD_DOTENV=1
